# The Architect — Environment Configuration
# Copy to .env and fill in your values
# NEVER commit this file to git

# Redis
ARCHITECT_REDIS_URL=redis://localhost:6379/0

# Ollama (local inference)
ARCHITECT_OLLAMA_HOST=http://localhost:11434
ARCHITECT_OLLAMA_DEFAULT_MODEL=qwen3.5:14b-q5_K_M

# Cloud API Keys (leave empty to disable)
ARCHITECT_ANTHROPIC_API_KEY=
ARCHITECT_XAI_API_KEY=
ARCHITECT_OPENROUTER_API_KEY=
ARCHITECT_VAST_API_KEY=

# Twilio (for notifications)
ARCHITECT_TWILIO_ACCOUNT_SID=
ARCHITECT_TWILIO_AUTH_TOKEN=
ARCHITECT_TWILIO_FROM_NUMBER=
ARCHITECT_NOTIFY_PHONE_NUMBER=

# Budget Limits (USD)
# ARCHITECT_BUDGET_TOTAL_DAILY=40.00
# ARCHITECT_BUDGET_TOTAL_MONTHLY=500.00
# ARCHITECT_BUDGET_CLAUDE_DAILY=10.00
# ARCHITECT_BUDGET_GROK_DAILY=5.00
